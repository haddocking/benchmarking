# Pinned versions for reproducible benchmark runs.
# When you change a value here, re-run setup.sh to
#  converge existing installs/clones to the new pin.

# which haddock3 version to be used e remote
# > use a commit (must exist on haddocking/haddock3)
# HADDOCK3_VERSION="e5b73f0b102c6c023f07d5ed4d7e8f65c1b2dccb"
# > use pypi version (must exist on pypi)
HADDOCK3_VERSION=2026.7.0

# which haddock-runner to be used - github release tag
HADDOCK_RUNNER_TAG=v4.0.0

# which commits of the benchmarks repositories to use

# https://github.com/haddocking/BM5-clean
BM5_CLEAN_REF=cd44a83f145b7a41411c3090e6341daa95546fe5
# https://github.com/haddocking/protein-peptide
PROTEIN_PEPTIDE_REF=8835d6a7744d278c83c209d657b260dcd149d3f0
# https://github.com/haddocking/Prot-DNABenchmark
PROT_DNA_BENCHMARK_REF=d5bd151a68ff610a5454489d8df4c962fe29f541
# https://github.com/haddocking/protein-glycans
PROTEIN_GLYCANS_REF=344e4a41a300b68b7ee3585895a460c863545ddb
# https://github.com/haddocking/shape-restrained-haddocking
SHAPE_RESTRAINED_HADDOCKING_REF=9032456ae00fc4103234b803c2a902abec5a9fcd


