# ── Benchmark datasets (downloaded/generated by each docking_benchmarks/*/setup.sh) ──
docking_benchmarks/protein_protein/protein-protein-dataset/
docking_benchmarks/protein_peptide/protein-peptide-dataset/
docking_benchmarks/protein_dna/protein-dna/
docking_benchmarks/protein_glycan/protein-glycan-dataset/
