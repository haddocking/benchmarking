# ── Virtual environment & Python ──────────────────────────────────────────────
.venv
env/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/

# ── HADDOCK & runner installation ─────────────────────────────────────────────
# (haddock3 lands in .venv/; uv + haddock-runner are prebuilt binaries in binaries/)
binaries/

# ── Benchmark datasets (downloaded/generated by each Docking_benchmarks/*/setup.sh) ──
Docking_benchmarks/Protein_Protein/protein-protein-dataset/
Docking_benchmarks/Protein_Peptide/protein-peptide-dataset/
Docking_benchmarks/Protein_DNA/protein-dna/
Docking_benchmarks/Protein_Glycan/protein-glycan-dataset/
Docking_benchmarks/Protein_Ligand_Shape/shape-restrained-haddocking/
Docking_benchmarks/Protein_Ligand_Shape/conformers/
Docking_benchmarks/Protein_Ligand_Shape/references/
Docking_benchmarks/Protein_Ligand_Shape/receptors/
Docking_benchmarks/Protein_Ligand_Shape/restraints/
Docking_benchmarks/Protein_Ligand_Shape/shapes/
Docking_benchmarks/Protein_Ligand_Shape/smiles/
Docking_benchmarks/Protein_Ligand_Shape/toppars/

# ── Generated input lists ─────────────────────────────────────────────────────
Docking_benchmarks/Protein_Protein/bm5-input.txt
Docking_benchmarks/Protein_Peptide/protein-peptide-input.txt
Docking_benchmarks/Protein_DNA/prot-dna-input.txt
Docking_benchmarks/Protein_Glycan/protein-glycan-input.txt
Docking_benchmarks/Protein_Ligand_Shape/protein-ligand-shape-input.txt

# ── Per-system setup logs (Setup/setup.sh redirects each dataset's output here) ──
Docking_benchmarks/*/.log

# ── Docking output directories ────────────────────────────────────────────────
results/
run*/
HADDOCK-*/

# ── SLURM & job logs ──────────────────────────────────────────────────────────
slurm-*.out
slurm-*.err
*.out
*.err
nohup.out

# ── Editor & OS artefacts ─────────────────────────────────────────────────────
*.swp
*.swo
*~
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
.ipynb_checkpoints/
